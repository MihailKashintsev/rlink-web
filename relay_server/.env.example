# Rlink Relay Server — environment variables
# Copy to .env and fill in your values before running docker-compose

# ── Admin panel ───────────────────────────────────────────────────────────
# SHA-256 hex hash of your admin password.
# Generate: echo -n "YourPassword" | shasum -a 256 | awk '{print $1}'
# Default app password is "Misha0000ff2010" → hash below (change in production!)
RELAY_ADMIN_HASH=8676c71fc75fa72489c87aa387b752ad816a4ea4476995da848c76fa06dae4fd

# ── VAPID (web push notifications) ───────────────────────────────────────
# Generate with: dart run relay_server/bin/generate_vapid_keys.sh
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY_PEM=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ── Self-hosted TURN (optional) ───────────────────────────────────────────
TURN_HOST=your.turn.server
TURN_USER=turnuser
TURN_PASSWORD=turnpassword
